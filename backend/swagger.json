{
  "openapi": "3.0.0",
  "info": {
    "title": "Prime Trade AI API",
    "version": "1.0.0",
    "description": "API documentation for Prime Trade AI assignment"
  },
  "servers": [
    { "url": "http://localhost:5000/api/v1" }
  ],
