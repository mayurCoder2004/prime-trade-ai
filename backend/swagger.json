    },
    "/tasks/{id}": {
      "get": { "summary": "Get task by id", "responses": { "200": { "description": "Task found" }, "404": { "description": "Not found" } } },
      "put": { "summary": "Update task", "requestBody": { "required": true }, "responses": { "200": { "description": "Task updated" }, "404": { "description": "Not found" } } },
      "delete": { "summary": "Delete task", "responses": { "200": { "description": "Task deleted" }, "404": { "description": "Not found" } } }
    }
  }
